---
import { getCollection } from "astro:content";
import Link from "../components/Link.astro";
import Base from "../layouts/Base.astro";
import { formatDate } from "../lib/posts";

const PAGE_SIZE = 10;

const allPosts = (
  await getCollection("posts", ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  })
).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const totalPages = Math.ceil(allPosts.length / PAGE_SIZE);
const posts = allPosts.slice(0, PAGE_SIZE);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base title="Posts">
  <h1>Posts</h1>
  <hr />
  <ul class="post-list">
    {
      posts.map((post) => (
        <li>
          <Link href={`/posts/${post.id}`} class="post-card-link">
            {post.data.cover && (
              <div class="post-card-img">
                <img src={`${base}${post.data.cover}`} alt="" />
              </div>
            )}
            <div class="post-card-text">
              {post.data.category && (
                <span class="category">{post.data.category}</span>
              )}
              <p class="post-card-title">{post.data.title}</p>
              <time datetime={post.data.date.toISOString().slice(0, 10)}>
                {formatDate(post.data.date)}
              </time>
            </div>
          </Link>
        </li>
      ))
    }
  </ul>
  {
    totalPages > 1 && (
      <div class="pagination">
        <span />
        <Link href="/2">Next</Link>
      </div>
    )
  }
</Base>
