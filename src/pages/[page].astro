---
import { getCollection } from "astro:content";
import Link from "../components/Link.astro";
import Base from "../layouts/Base.astro";
import { formatDate } from "../lib/posts";

export async function getStaticPaths() {
  const pageSize = 10;
  const allPosts = await getCollection("posts", ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  });
  const totalPages = Math.ceil(allPosts.length / pageSize);
  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, i) => ({
    params: { page: String(i + 2) },
  }));
}

const pageSize = 10;
const allPosts = (
  await getCollection("posts", ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  })
).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const totalPages = Math.ceil(allPosts.length / pageSize);
const page = parseInt(Astro.params.page!, 10);
const start = (page - 1) * pageSize;
const posts = allPosts.slice(start, start + pageSize);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base title={`Page ${page}`}>
  <h1>Posts</h1>
  <hr />
  <ul class="post-list">
    {
      posts.map((post) => (
        <li>
          <Link href={`/posts/${post.id}`} class="post-card-link">
            {post.data.cover && (
              <div class="post-card-img">
                <img src={`${base}${post.data.cover}`} alt="" />
              </div>
            )}
            <div class="post-card-text">
              {post.data.category && (
                <span class="category">{post.data.category}</span>
              )}
              <p class="post-card-title">{post.data.title}</p>
              <time datetime={post.data.date.toISOString().slice(0, 10)}>
                {formatDate(post.data.date)}
              </time>
            </div>
          </Link>
        </li>
      ))
    }
  </ul>
  <div class="pagination">
    <Link href={page === 2 ? "/" : `/${page - 1}`}>Prev</Link>
    {page < totalPages ? <Link href={`/${page + 1}`}>Next</Link> : <span />}
  </div>
</Base>
